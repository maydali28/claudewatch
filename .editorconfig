root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
# Mirrors prettier's printWidth: 100 (see .prettierrc / prettier.config) so
# editors without a Prettier integration still wrap at the same column.
max_line_length = 100
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
