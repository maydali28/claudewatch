# ─── Environment variable reference ──────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
#
# VITE_*         → injected into the renderer bundle automatically by Vite
# MAIN_VITE_*    → injected into the main process bundle by electron-vite

# Sentry DSN for crash reports and user feedback.
# Get this from: https://sentry.io → your project → Settings → Client Keys (DSN)
MAIN_VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Base URL for the auto-updater release feed (Hazel or generic provider).
MAIN_VITE_RELEASE_SERVER_URL=https://releases.example.com/claudewatch

# GitHub releases base URL used to fetch and verify release manifests.
MAIN_VITE_GITHUB_RELEASES_URL=https://github.com/maydali28/claudewatch/releases/download

# Homebrew cask name used in `brew upgrade --cask <name>` on macOS.
MAIN_VITE_BREW_CASK_NAME=claudewatch

# Project website URL shown in About panels.
VITE_WEBSITE_URL=https://claudewatch.mohamedalimay.dev

# GitHub repository URL shown in About panels.
VITE_REPO_URL=https://github.com/maydali28/claudewatch

# Set to "true" to open a bundle size visualiser after pnpm build (opens bundle/stats.html).
ANALYZE=false

# ─── CI-only (do not put in .env.local) ──────────────────────────────────────
# Code-signing certificate — set in CI secrets, not locally.
# CSC_LINK=path/to/cert.p12
# CSC_KEY_PASSWORD=your_certificate_password
