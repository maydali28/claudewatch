node-linker=hoisted
shamefully-hoist=true
# pnpm 10.19's bundled node-gyp@10.2 transitively depends on the deprecated
# @npmcli/move-file, which crashes on Node >=22 ("ERR_INVALID_ARG_TYPE … at
# promisify"). That breaks the implicit `node-gyp rebuild` for native deps
# like macos-alias and fs-xattr. node-gyp 11 dropped that dependency.
# Pin a project-local node-gyp 11 so all install scripts use it.
node-gyp=node_modules/node-gyp/bin/node-gyp.js
